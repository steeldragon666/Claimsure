{
  "name": "@cpa/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "cross-env LOG_LEVEL=silent tsx --env-file-if-exists=../../.env --test --test-force-exit \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@cpa/agents": "workspace:*",
    "@cpa/audit-score": "workspace:*",
    "@cpa/auth": "workspace:*",
    "@cpa/db": "workspace:*",
    "@cpa/documents": "workspace:*",
    "@cpa/email": "workspace:*",
    "@cpa/integrations": "workspace:*",
    "@cpa/observability": "workspace:*",
    "@cpa/schemas": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "fastify": "^5.2.0",
    "fastify-type-provider-zod": "^4.0.2",
    "openid-client": "^5.7.1",
    "pg-boss": "^12.18.2",
    "stripe": "^17.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@types/node": "^22.10.0",
    "cross-env": "^7.0.3",
    "jose": "^5.10.0",
    "nock": "^14.0.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
