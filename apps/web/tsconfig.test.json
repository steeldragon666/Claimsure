{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "es2023"],
    "noEmit": true,
    "rootDir": "./src",
    "exactOptionalPropertyTypes": false,
    "verbatimModuleSyntax": false,
    "moduleResolution": "bundler",
    "module": "esnext",
    "jsx": "preserve",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
