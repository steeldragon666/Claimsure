# ArchiveOne / CPA Platform — production env (example, minimal)
#
# This file only documents the backup-related variables. The full production
# template (DB URLs, JWT secrets, OAuth client IDs, etc.) lives on branch
# `feat/vps-staging-deployment`. Merge from there or copy alongside.

# ---------------------------------------------------------------------------
# Nightly backup (tools/vps/backup.sh) — also loaded by systemd from
# /etc/cpa/backup.env in production. Keep this file in sync.
# ---------------------------------------------------------------------------

# restic repository URL. S3-compatible, e.g.
#   s3:https://s3.ap-southeast-2.amazonaws.com/<bucket>
RESTIC_REPOSITORY=

# Long random passphrase. Store in 1Password — LOSING THIS = LOSING BACKUPS.
RESTIC_PASSWORD=

# Scoped IAM credentials with PutObject/GetObject/ListBucket on the bucket.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Bucket name (informational; restic uses the full URL above).
BACKUP_S3_BUCKET=

# ---------------------------------------------------------------------------
# Object storage — MinIO (evidence vault, brand logos, rendered PDFs).
# The `minio` service in compose.prod.yml reads MINIO_*; the API reads S3_*.
# Use the MinIO root credentials as the S3 access key/secret for v1.
# ---------------------------------------------------------------------------

# MinIO root credentials (container). MINIO_ROOT_USER doubles as the S3
# access key id below; MINIO_ROOT_PASSWORD as the secret.
MINIO_ROOT_USER=archiveone
MINIO_ROOT_PASSWORD=

# Comma-separated browser origins allowed to PUT directly to presigned URLs.
MINIO_CORS_ALLOW_ORIGIN=https://archiveone.com.au,https://www.archiveone.com.au

# S3 client config consumed by the API (apps/api/src/lib/storage.ts).
# Endpoint is the PUBLIC host so presigned URLs the browser/mobile receive
# resolve + their SigV4 signature matches. Path-style avoids wildcard DNS.
S3_ENDPOINT=https://s3.archiveone.com.au
S3_REGION=us-east-1
S3_BUCKET=archiveone-evidence
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY_ID=archiveone
S3_SECRET_ACCESS_KEY=
