# ─────────────────────────────────────────────────────────────────────────
# .env.production.example — VPS staging deployment template.
#
# Copy to `.env.production` on the VPS (NOT in the repo, NOT committed).
# Fill in real values before running `docker compose up -d --build`.
#
# All secrets here MUST be generated fresh per environment. Never reuse
# dev keys in staging. Never commit this file with real values.
# ─────────────────────────────────────────────────────────────────────────

# ─── Domain + TLS ───────────────────────────────────────────────────────
# The domain Caddy serves on. Must have an A-record pointing at this
# VPS's public IP before bringing up the caddy container (Let's Encrypt
# challenge will fail otherwise).
DOMAIN=staging.cpa-platform.example

# Email Caddy uses for Let's Encrypt account registration + expiry alerts.
ACME_EMAIL=ops@example.com

# Public-facing base URL the api + web reference. Includes scheme.
PUBLIC_BASE_URL=https://staging.cpa-platform.example

# ─── Postgres ───────────────────────────────────────────────────────────
# Default app-owner credentials. Generate with: openssl rand -hex 32
POSTGRES_USER=cpa
POSTGRES_PASSWORD=REPLACE_WITH_OPENSSL_RAND_HEX_32
POSTGRES_DB=cpa_prod

# Application role password (cpa_app — the runtime, RLS-respecting user).
# Generate with: openssl rand -hex 32
CPA_APP_PASSWORD=REPLACE_WITH_OPENSSL_RAND_HEX_32

# ─── API auth ───────────────────────────────────────────────────────────
# Session JWT signing secret (32+ bytes). Generate with: openssl rand -hex 64
SESSION_JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_HEX_64

# Microsoft Entra OAuth — register an app at https://entra.microsoft.com
# and set redirect URI to ${PUBLIC_BASE_URL}/v1/auth/microsoft/callback
MICROSOFT_CLIENT_ID=REPLACE
MICROSOFT_CLIENT_SECRET=REPLACE
# 'common' = multi-tenant; specific GUID = single-tenant
MICROSOFT_TENANT_ID=common

# ─── Anthropic ──────────────────────────────────────────────────────────
# Used by the agents package (classify, narrative-drafter, etc.)
ANTHROPIC_API_KEY=sk-ant-REPLACE

# ─── Stripe ─────────────────────────────────────────────────────────────
# Use sk_test_* keys for staging; sk_live_* only on real production.
STRIPE_SECRET_KEY=sk_test_REPLACE
# Get from Stripe webhook dashboard after pointing webhook at
# ${PUBLIC_BASE_URL}/v1/billing/webhook
STRIPE_WEBHOOK_SECRET=whsec_REPLACE

# ─── Resend (transactional email) ──────────────────────────────────────
RESEND_API_KEY=re_REPLACE

# ─── Sentry (error tracking) ────────────────────────────────────────────
# Optional but recommended; create a Node project at sentry.io
SENTRY_DSN=https://REPLACE@sentry.io/REPLACE

# ─── Logging ────────────────────────────────────────────────────────────
# trace | debug | info | warn | error | fatal
LOG_LEVEL=info
