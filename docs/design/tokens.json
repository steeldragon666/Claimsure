{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "ArchiveOne design tokens — System A (locked 2026-05-27). Runtime source of truth is apps/web/src/app/globals.css; this file mirrors it. Legacy cream/green (System B) retired.",
  "$version": "2.0.0",
  "$lastUpdated": "2026-05-27",

  "color": {
    "base": {
      "$value": "#0b0b0d",
      "$type": "color",
      "$description": "Page background, ink (dark)"
    },
    "surface": {
      "$value": "#131316",
      "$type": "color",
      "$description": "Cards, dialogs, raised surfaces (ink2)"
    },
    "surfaceMuted": {
      "$value": "#1c1c20",
      "$type": "color",
      "$description": "Disabled/inert surfaces (ink3)"
    },

    "ink": {
      "$value": "#f0ebe2",
      "$type": "color",
      "$description": "Primary text, bone"
    },
    "inkMuted": {
      "$value": "#cdc7bd",
      "$type": "color",
      "$description": "Secondary text, body subtle (bone2)"
    },
    "inkSubtle": { "$value": "#8a857c", "$type": "color", "$description": "Captions, metadata (bone3)" },

    "hairline": {
      "$value": "rgba(240,235,226,0.10)",
      "$type": "color",
      "$description": "Borders, dividers (rule)"
    },
    "hairlineStrong": {
      "$value": "rgba(240,235,226,0.22)",
      "$type": "color",
      "$description": "Strong borders, focused states (rule-strong)"
    },

    "accent": { "$value": "#e1a23a", "$type": "color", "$description": "Amber, signature accent" },
    "accentStrong": {
      "$value": "#b88a3d",
      "$type": "color",
      "$description": "Hover/active, accent emphasis (amber-soft)"
    },
    "accentSubtle": {
      "$value": "#2a2114",
      "$type": "color",
      "$description": "Tinted backgrounds, dark amber surface"
    },

    "success": {
      "$value": "#5C7A6B",
      "$type": "color",
      "$description": "Same as accent — verified reads as primary"
    },
    "warning": {
      "$value": "#B8732B",
      "$type": "color",
      "$description": "Terracotta, R&DTI flag (not amber)"
    },
    "error": { "$value": "#9E3838", "$type": "color", "$description": "Clay red, never pure red" },
    "info": { "$value": "#5A6478", "$type": "color", "$description": "Slate, system messages" }
  },

  "typography": {
    "fontFamily": {
      "display": {
        "$value": "Fraunces",
        "$type": "fontFamily",
        "$description": "Variable serif, opsz 9-144, wght 100-900",
        "fallback": ["Georgia", "serif"]
      },
      "body": {
        "$value": "Inter Tight",
        "$type": "fontFamily",
        "$description": "Humanist sans, dense setting",
        "fallback": ["system-ui", "sans-serif"],
        "alternateChoice": "General Sans (Fontshare) — swap if Inter family is to be avoided entirely"
      },
      "mono": {
        "$value": "JetBrains Mono",
        "$type": "fontFamily",
        "$description": "Monospace with tabular figures, for forensic data",
        "fallback": ["ui-monospace", "monospace"]
      }
    },

    "scale": {
      "display2xl": {
        "size": "56px",
        "lineHeight": "1.05",
        "weight": "600",
        "tracking": "-0.04em",
        "family": "display",
        "$description": "Marketing/login wordmark only"
      },
      "displayXl": {
        "size": "44px",
        "lineHeight": "1.10",
        "weight": "600",
        "tracking": "-0.03em",
        "family": "display",
        "$description": "Page-level page titles"
      },
      "displayLg": {
        "size": "32px",
        "lineHeight": "1.15",
        "weight": "600",
        "tracking": "-0.02em",
        "family": "display",
        "$description": "Section heads (FY24, claim title)"
      },
      "displayMd": {
        "size": "24px",
        "lineHeight": "1.20",
        "weight": "600",
        "tracking": "-0.01em",
        "family": "display",
        "$description": "Card heads, dialog titles"
      },
      "displaySm": {
        "size": "20px",
        "lineHeight": "1.25",
        "weight": "600",
        "tracking": "0",
        "family": "display",
        "$description": "Subsection heads"
      },

      "bodyLg": {
        "size": "16px",
        "lineHeight": "1.50",
        "weight": "400",
        "tracking": "0",
        "family": "body",
        "$description": "Default body, prose"
      },
      "bodyMd": {
        "size": "14px",
        "lineHeight": "1.45",
        "weight": "400",
        "tracking": "0",
        "family": "body",
        "$description": "Dense UI body, table cells"
      },
      "bodySm": {
        "size": "12px",
        "lineHeight": "1.40",
        "weight": "400",
        "tracking": "0.01em",
        "family": "body",
        "$description": "Captions, metadata, footnotes"
      },

      "monoMd": {
        "size": "14px",
        "lineHeight": "1.45",
        "weight": "400",
        "tracking": "0",
        "family": "mono",
        "$description": "Forensic data inline"
      },
      "monoSm": {
        "size": "12px",
        "lineHeight": "1.40",
        "weight": "400",
        "tracking": "0",
        "family": "mono",
        "$description": "Forensic chips, hash badges"
      }
    }
  },

  "spacing": {
    "consultant": {
      "2xs": { "$value": "2px", "$type": "dimension" },
      "xs": { "$value": "4px", "$type": "dimension" },
      "sm": { "$value": "8px", "$type": "dimension" },
      "md": { "$value": "12px", "$type": "dimension" },
      "lg": { "$value": "16px", "$type": "dimension" },
      "xl": { "$value": "24px", "$type": "dimension" },
      "2xl": { "$value": "32px", "$type": "dimension" },
      "3xl": { "$value": "48px", "$type": "dimension" },
      "4xl": { "$value": "64px", "$type": "dimension" }
    },
    "claimant": {
      "xs": { "$value": "8px", "$type": "dimension" },
      "sm": { "$value": "16px", "$type": "dimension" },
      "md": { "$value": "24px", "$type": "dimension" },
      "lg": { "$value": "32px", "$type": "dimension" },
      "xl": { "$value": "48px", "$type": "dimension" },
      "2xl": { "$value": "64px", "$type": "dimension" },
      "3xl": { "$value": "96px", "$type": "dimension" }
    }
  },

  "radius": {
    "none": { "$value": "0", "$type": "dimension" },
    "sm": { "$value": "4px", "$type": "dimension", "$description": "Buttons, inputs" },
    "md": { "$value": "8px", "$type": "dimension", "$description": "Cards" },
    "lg": { "$value": "12px", "$type": "dimension", "$description": "Dialogs, popovers, toasts" },
    "full": { "$value": "9999px", "$type": "dimension", "$description": "Pills, forensic chips" }
  },

  "shadow": {
    "soft": {
      "$value": "0 1px 2px rgba(26, 24, 20, 0.04), 0 1px 1px rgba(26, 24, 20, 0.02)",
      "$type": "shadow",
      "$description": "Raised cards, default lift"
    },
    "medium": {
      "$value": "0 4px 8px rgba(26, 24, 20, 0.06), 0 2px 4px rgba(26, 24, 20, 0.04)",
      "$type": "shadow",
      "$description": "Floating elements (popovers)"
    },
    "high": {
      "$value": "0 12px 24px rgba(26, 24, 20, 0.08), 0 4px 8px rgba(26, 24, 20, 0.06)",
      "$type": "shadow",
      "$description": "Dialogs, modals"
    },
    "embossed": {
      "$value": "inset 0 1px 0 rgba(255, 255, 255, 0.4), inset 0 -1px 0 rgba(26, 24, 20, 0.04)",
      "$type": "shadow",
      "$description": "Forensic chip inset, registry-stamp feel"
    }
  },

  "motion": {
    "easing": {
      "standard": {
        "$value": "cubic-bezier(0.4, 0, 0.2, 1)",
        "$type": "cubicBezier",
        "$description": "Default ease-out"
      },
      "enter": { "$value": "cubic-bezier(0.0, 0, 0.2, 1)", "$type": "cubicBezier" },
      "exit": { "$value": "cubic-bezier(0.4, 0, 1, 1)", "$type": "cubicBezier" }
    },
    "duration": {
      "micro": { "$value": "100ms", "$type": "duration", "$description": "Hover/focus state" },
      "short": {
        "$value": "200ms",
        "$type": "duration",
        "$description": "State transitions, including chain-verify pulse"
      },
      "medium": {
        "$value": "300ms",
        "$type": "duration",
        "$description": "View transitions, dialogs"
      },
      "long": { "$value": "500ms", "$type": "duration", "$description": "Reserved, rarely used" }
    }
  },

  "components": {
    "forensicChip": {
      "$description": "The most-repeated visual element. Renders inline next to every claim-bearing artefact.",
      "shape": "pill",
      "border": "{color.hairline}",
      "background": "{color.surfaceMuted}",
      "padding": {
        "default": "{spacing.consultant.xs} {spacing.consultant.sm}",
        "dense": "{spacing.consultant.2xs} {spacing.consultant.xs}"
      },
      "fontFamily": "{typography.fontFamily.mono}",
      "fontSize": "{typography.scale.monoSm.size}",
      "states": {
        "default": { "border": "{color.hairline}" },
        "verifying": {
          "border": "{color.accent}",
          "animation": "verify-pulse 200ms ease-out forwards"
        },
        "verified": {
          "border": "{color.accent}",
          "icon": "checkmark",
          "iconColor": "{color.accent}"
        },
        "broken": { "border": "{color.error}", "icon": "x", "iconColor": "{color.error}" }
      }
    },
    "agentChip": {
      "$description": "Distinguishes agent contributions from consultant authorship.",
      "shape": "pill",
      "border": "{color.accent}",
      "background": "{color.accentSubtle}",
      "padding": "{spacing.consultant.xs} {spacing.consultant.sm}",
      "fontFamily": "{typography.fontFamily.body}",
      "fontSize": "{typography.scale.bodySm.size}",
      "format": "Drafted by {agentName} · {versionPin}",
      "versionPinFamily": "{typography.fontFamily.mono}"
    },
    "transitionBadge": {
      "$description": "Multi-cycle timeline gutter badge.",
      "shape": "pill",
      "fontFamily": "{typography.fontFamily.mono}",
      "fontSize": "{typography.scale.monoSm.size}",
      "variants": {
        "continuation": { "background": "{color.accentSubtle}", "color": "{color.accentStrong}" },
        "pivot": { "background": "#F5E4D5", "color": "{color.warning}" },
        "completion": { "background": "#E1E5EB", "color": "{color.info}" },
        "abandoned": {
          "background": "transparent",
          "color": "{color.inkMuted}",
          "border": "1px dashed {color.inkSubtle}"
        }
      }
    }
  },

  "accessibility": {
    "wcagLevel": "AA",
    "contrastRatios": {
      "ink-on-base": 12.8,
      "ink-on-surface": 13.4,
      "inkMuted-on-base": 5.2,
      "accent-on-base": 4.7,
      "accent-on-surface": 7.1
    },
    "focusRing": {
      "color": "{color.accent}",
      "width": "2px",
      "offset": "2px",
      "style": "solid"
    },
    "reducedMotion": "respected globally via prefers-reduced-motion: all transitions become instant"
  }
}
