POSTGRES_PASSWORD=replace-with-a-long-random-password
CPA_APP_PASSWORD=replace-with-a-different-long-random-password

# `?sslmode=disable` is REQUIRED for container-to-container postgres
# connections. The postgres image doesn't have TLS configured (and
# doesn't need it on a docker bridge network), but the `pg` library
# defaults to ssl=true when NODE_ENV=production, causing pg-boss to
# error: "The server does not support SSL connections". The opt-out
# travels in the URL itself.
DATABASE_URL=postgres://cpa:replace-with-a-long-random-password@postgres:5432/archiveone?sslmode=disable
DATABASE_URL_APP=postgres://cpa_app:replace-with-a-different-long-random-password@postgres:5432/archiveone?sslmode=disable
DATABASE_POOL_MAX=10

NODE_ENV=production
API_PORT=3000
API_URL=http://api:3000
PUBLIC_BASE_URL=https://archiveone.com.au
APP_BASE_URL=https://archiveone.com.au
WEB_BASE_URL=https://archiveone.com.au

SESSION_JWT_SECRET=replace-with-32-plus-random-bytes-never-dev-default
SIGNUP_VERIFICATION_SECRET=replace-with-different-32-plus-random-bytes
SESSION_COOKIE_NAME=archiveone_session
SESSION_TTL_SECONDS=86400

SIGNUP_EMAIL_MODE=manual
SIGNUP_FROM_ADDRESS=ArchiveOne <noreply@archiveone.com.au>
RESEND_API_KEY=

# === Founder signup notifications + 1-click magic-link override ===
# When FOUNDER_NOTIFICATION_EMAIL is set, every autonomous signup (both
# approves and denies) sends a notification email. For deny+claude_deny,
# the email includes a 1-click HMAC link to override the deny.
# Comma-separated for multiple founders. Leave blank to disable the feature.
FOUNDER_NOTIFICATION_EMAIL=
# REQUIRED when FOUNDER_NOTIFICATION_EMAIL is set. 32+ bytes of entropy
# (the boot path throws if missing). Used to HMAC the override link.
FOUNDER_OVERRIDE_SECRET=
# Optional from-address override for both the founder notification AND the
# applicant signin email. Falls back to BETA_FROM_ADDRESS then the default.
FOUNDER_FROM_ADDRESS=

CLASSIFIER_IMPL=stub
EXPENDITURE_CLASSIFIER_IMPL=stub
DOCUMENT_ANALYZER_IMPL=mock
APPLICATION_DRAFTER_IMPL=stub
XERO_IMPL=stub

P6_AGENT_A_ENABLED=false
P6_AGENT_B_ENABLED=false
P6_AGENT_C_ENABLED=false
P6_AGENT_C_STREAMING_ENABLED=false

TOKEN_ENCRYPTION_KEY=replace-with-64-hex-chars
CLOUD_SYNC_TOKEN_KEY=replace-with-64-hex-chars

# === Sentry error tracking ===
# Leave blank to disable Sentry (a one-line console.warn is emitted on boot).
# When set, both apps/api and apps/web forward errors to Sentry with PII
# scrubbing (no email, no IP, no cookies, no Authorization header).
SENTRY_DSN=
# Required only for source-map upload at build time.
SENTRY_ORG=
SENTRY_PROJECT=
# Optional — only needed at build time to upload source maps.
SENTRY_AUTH_TOKEN=
# Optional release identifier override (defaults to git commit SHA).
SENTRY_RELEASE=
