{
  "name": "@cpa/agents",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./classifier": {
      "types": "./dist/classifier/index.d.ts",
      "import": "./dist/classifier/index.js"
    },
    "./classifier-expenditure": {
      "types": "./dist/classifier-expenditure/index.d.ts",
      "import": "./dist/classifier-expenditure/index.js"
    },
    "./synthesizer-register": {
      "types": "./dist/synthesizer-register/index.d.ts",
      "import": "./dist/synthesizer-register/index.js"
    },
    "./narrative-drafter": {
      "types": "./dist/narrative-drafter/index.d.ts",
      "import": "./dist/narrative-drafter/index.js"
    },
    "./multi-cycle": {
      "types": "./dist/multi-cycle/index.d.ts",
      "import": "./dist/multi-cycle/index.js"
    },
    "./suggestion-evaluator": {
      "types": "./dist/suggestion-evaluator/index.d.ts",
      "import": "./dist/suggestion-evaluator/index.js"
    },
    "./multi-entity-similarity": {
      "types": "./dist/multi-entity-similarity/index.d.ts",
      "import": "./dist/multi-entity-similarity/index.js"
    },
    "./regulatory-classifier": {
      "types": "./dist/regulatory-classifier/index.d.ts",
      "import": "./dist/regulatory-classifier/index.js"
    },
    "./document-analyzer": {
      "types": "./dist/document-analyzer/index.d.ts",
      "import": "./dist/document-analyzer/index.js"
    },
    "./ip-search-query": {
      "types": "./dist/ip-search-query/index.d.ts",
      "import": "./dist/ip-search-query/index.js"
    },
    "./ip-search-verdict": {
      "types": "./dist/ip-search-verdict/index.d.ts",
      "import": "./dist/ip-search-verdict/index.js"
    },
    "./signup-evaluator": {
      "types": "./dist/signup-evaluator/index.d.ts",
      "import": "./dist/signup-evaluator/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "tsx --env-file-if-exists=../../.env --test --test-force-exit \"src/**/*.test.ts\" \"eval/**/*.test.ts\"",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.eval.json --noEmit",
    "lint": "eslint src eval",
    "eval:expenditure": "tsx --env-file-if-exists=../../.env eval/expenditure-classifier/run.ts",
    "eval:register": "tsx --env-file-if-exists=../../.env eval/register-synthesizer/run.ts",
    "eval:narrative": "tsx --env-file-if-exists=../../.env eval/narrative-drafter/run.ts",
    "eval:all": "pnpm eval:expenditure && pnpm eval:register && pnpm eval:narrative"
  },
  "dependencies": {
    "@cpa/db": "workspace:*",
    "@cpa/observability": "workspace:*",
    "@cpa/schemas": "workspace:*",
    "@anthropic-ai/sdk": "^0.32.1",
    "@opentelemetry/api": "^1.9.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "nock": "^14.0.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
